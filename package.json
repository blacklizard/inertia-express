{
  "name": "inertia-express-monorepo",
  "version": "0.0.0",
  "description": "Monorepo for @blacklizard/inertia-express — a production-ready, TypeScript-first Inertia.js v3 server adapter for Express.js, plus its Redis cache store and SSR worker.",
  "private": true,
  "type": "module",
  "license": "MIT",
  "author": "blacklizard",
  "homepage": "https://github.com/blacklizard/inertia-express#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blacklizard/inertia-express.git"
  },
  "bugs": {
    "url": "https://github.com/blacklizard/inertia-express/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "test": "pnpm -r --filter \"./packages/*\" test",
    "typecheck": "pnpm -r --filter \"./packages/*\" typecheck",
    "clean": "pnpm -r --filter \"./packages/*\" clean",
    "lint": "eslint \"packages/*/src/**/*.ts\"",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "test:conformance": "conformance/run.sh",
    "docs:dev": "pnpm --filter inertia-express-docs dev",
    "docs:build": "pnpm --filter inertia-express-docs build",
    "docs:preview": "pnpm --filter inertia-express-docs preview"
  },
  "devDependencies": {
    "@blacklizard/eslint-blacklizard": "^1.0.1",
    "eslint": "^10.4.0",
    "typescript": "catalog:"
  }
}
