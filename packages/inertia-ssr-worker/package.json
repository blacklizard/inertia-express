{
  "name": "@blacklizard/inertia-ssr-worker",
  "version": "0.1.0",
  "description": "Production SSR worker for Inertia.js v3 — wraps your render function with health/readiness endpoints, request/uptime/RSS-based recycling, and graceful drain.",
  "type": "module",
  "license": "MIT",
  "author": "blacklizard",
  "homepage": "https://github.com/blacklizard/inertia-express/tree/main/packages/inertia-ssr-worker#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/blacklizard/inertia-express.git",
    "directory": "packages/inertia-ssr-worker"
  },
  "bugs": {
    "url": "https://github.com/blacklizard/inertia-express/issues"
  },
  "engines": {
    "node": ">=24"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm clean && pnpm build && pnpm test"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "keywords": [
    "inertia",
    "inertia-js",
    "inertiajs",
    "express",
    "adapter",
    "ssr",
    "spa",
    "redis",
    "cache",
    "worker",
    "load-balancer",
    "self-healing"
  ]
}
